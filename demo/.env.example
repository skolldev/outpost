# Copy the values you need into the REPO-ROOT .env (compose only reads it there).
# demo/scripts/print-dsns.sh --write-env fills in the project ids for you.

# Project ids of the seeded demo projects (DB-assigned; NOT guaranteed 1/2).
DEMO_FRONTEND_PROJECT_ID=1
DEMO_BACKEND_PROJECT_ID=2

# Environment reported by both SDKs (dev | qa | prod — anything goes).
DEMO_SENTRY_ENVIRONMENT=dev

# Set to false to silence the backend's ambient traffic generator.
DEMO_TRAFFIC=true

# Outpost API token with artifacts:write scope (UI → Settings → API tokens).
# When set, the demo-frontend container self-uploads its source maps at start,
# so frontend stacktraces arrive symbolicated.
SENTRY_AUTH_TOKEN=
